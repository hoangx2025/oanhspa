generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Brand {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  tagline     String?
  heroNote    String?
  heroImage   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  Product[]
}

model Product {
  id                Int      @id @default(autoincrement())
  handle            String   @unique
  title             String
  short             String?
  description       String?
  imageHint         String?
  isHot             Boolean  @default(false)
  isBest            Boolean  @default(false)
  flashSaleEndsAt   DateTime?
  youtubeUrl        String?

  brandId           Int
  brand             Brand    @relation(fields: [brandId], references: [id])

  categoryId        Int
  category          Category @relation(fields: [categoryId], references: [id])

  variants          Variant[]
  images            ProductImage[]
  marketplaces      MarketplaceLink[]
  orderItems        OrderItem[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([brandId])
  @@index([categoryId])
}

model Variant {
  id          Int      @id @default(autoincrement())
  productId   Int
  name        String
  value       String
  price       Int
  compareAt   Int?
  stock       Int      @default(0)
  sku         String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model File {
  id        Int      @id @default(autoincrement())
  url       String   @unique
  name      String?
  mimeType  String?
  kind      String   @default("IMAGE")
  createdAt DateTime @default(now())

  productImages ProductImage[]
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  fileId    Int
  sortOrder Int      @default(0)
  alt       String?

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([fileId])
  @@unique([productId, fileId])
}

model MarketplaceLink {
  id        Int      @id @default(autoincrement())
  productId Int
  platform  String
  productUrl String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model AspNetUsers {
  id                   String    @id @default(cuid())
  userName             String?   @unique
  normalizedUserName   String?   @unique
  email                String?   @unique
  normalizedEmail      String?   @unique
  emailConfirmed       Boolean   @default(false)
  passwordHash         String?
  securityStamp        String?
  concurrencyStamp     String?
  phoneNumber          String?
  phoneNumberConfirmed Boolean   @default(false)
  twoFactorEnabled     Boolean   @default(false)
  lockoutEnd           DateTime?
  lockoutEnabled       Boolean   @default(true)
  accessFailedCount    Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  userRoles   AspNetUserRoles[]
  userClaims  AspNetUserClaims[]
  userLogins  AspNetUserLogins[]
  userTokens  AspNetUserTokens[]
}

model AspNetRoles {
  id               String  @id @default(cuid())
  name             String? @unique
  normalizedName   String? @unique
  concurrencyStamp String?
  userRoles  AspNetUserRoles[]
  roleClaims AspNetRoleClaims[]
}

model AspNetUserRoles {
  userId String
  roleId String
  user AspNetUsers @relation(fields: [userId], references: [id], onDelete: Cascade)
  role AspNetRoles @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@id([userId, roleId])
  @@index([roleId])
}

model AspNetUserClaims {
  id         Int     @id @default(autoincrement())
  userId     String
  claimType  String?
  claimValue String?
  user AspNetUsers @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model AspNetRoleClaims {
  id         Int     @id @default(autoincrement())
  roleId     String
  claimType  String?
  claimValue String?
  role AspNetRoles @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@index([roleId])
}

model AspNetUserLogins {
  loginProvider       String
  providerKey         String
  providerDisplayName String?
  userId              String
  user AspNetUsers @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([loginProvider, providerKey])
  @@index([userId])
}

model AspNetUserTokens {
  userId        String
  loginProvider String
  name          String
  value         String?
  user AspNetUsers @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([userId, loginProvider, name])
}

model Order {
  id         Int         @id @default(autoincrement())
  platform   String      // shopee | lazada | tiki | sendo | website | other
  externalId String?     // mã đơn hàng trên sàn
  orderedAt  DateTime    @default(now())
  status     String      @default("completed") // completed | pending | cancelled | returned
  note       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  items      OrderItem[]

  @@index([platform])
  @@index([orderedAt])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  variantId Int?
  quantity  Int     @default(1)
  price     Int     // giá tại thời điểm đặt hàng

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model S3Config {
  id              Int      @id @default(autoincrement())
  label           String   @default("default")
  bucket          String
  region          String
  accessKeyId     String
  secretAccessKey String
  endpoint        String?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
