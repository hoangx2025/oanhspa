generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─────────────────────────────────────────────
// SHOPEE SHOP — credentials & token API
// ─────────────────────────────────────────────
model ShopeeShop {
  id           Int       @id @default(autoincrement())
  shopId       String    @unique  // Shopee shop_id (số lớn, lưu String)
  shopName     String?
  region       String    @default("VN")
  partnerId    String    // Shopee partner_id
  partnerKey   String    // Shopee partner_key (dùng để ký request)
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  products Product[]
  orders   Order[]
  syncLogs SyncLog[]
}

// ─────────────────────────────────────────────
// SYNC LOG — lịch sử chạy job sync
// ─────────────────────────────────────────────
model SyncLog {
  id               Int       @id @default(autoincrement())
  shopId           Int
  type             String    // product | order | stock | shipment
  status           String    @default("running") // running | success | error
  message          String?
  recordsProcessed Int       @default(0)
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?

  shop ShopeeShop @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([type, status])
}

// ─────────────────────────────────────────────
// BRAND / CATEGORY
// ─────────────────────────────────────────────
model Brand {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  tagline   String?
  heroNote  String?
  heroImage String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

// ─────────────────────────────────────────────
// PRODUCT
// ─────────────────────────────────────────────
model Product {
  id              Int       @id @default(autoincrement())
  handle          String    @unique
  title           String
  short           String?
  description     String?
  imageHint       String?
  isHot           Boolean   @default(false)
  isBest          Boolean   @default(false)
  flashSaleEndsAt DateTime?
  youtubeUrl      String?

  brandId    Int
  brand      Brand    @relation(fields: [brandId], references: [id])
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  // Shopee sync
  shopeeShopId Int?
  shopeeShop   ShopeeShop? @relation(fields: [shopeeShopId], references: [id])
  shopeeItemId String?     // Shopee item_id
  syncedAt     DateTime?   // lần cuối sync từ Shopee
  syncStatus   String?     // synced | pending | error | manual

  variants   Variant[]
  images     ProductImage[]
  marketplaces MarketplaceLink[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([categoryId])
  @@index([shopeeShopId])
  @@unique([shopeeShopId, shopeeItemId])
}

// ─────────────────────────────────────────────
// VARIANT
// ─────────────────────────────────────────────
model Variant {
  id            Int     @id @default(autoincrement())
  productId     Int
  name          String
  value         String
  price         Int
  compareAt     Int?
  stock         Int     @default(0)
  sku           String?
  sortOrder     Int     @default(0)

  // Shopee sync
  shopeeModelId String? // Shopee model_id
  shopeeTierIdx String? // JSON: vị trí trong tier, vd "[0,1]"

  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─────────────────────────────────────────────
// UNIT — đơn vị biến thể (Dung tích, Màu sắc…)
// ─────────────────────────────────────────────
model Unit {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// FILE / IMAGE
// ─────────────────────────────────────────────
model File {
  id              Int       @id @default(autoincrement())
  key             String?   // S3 object key
  url             String    @unique // permanent URL (stable ID)
  presignedUrl    String?   // cached presigned GET URL
  presignedExpiry DateTime?
  name            String?
  mimeType        String?
  kind            String    @default("IMAGE")
  createdAt       DateTime  @default(now())

  productImages ProductImage[]
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  fileId    Int
  sortOrder Int     @default(0)
  alt       String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  file    File    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([fileId])
  @@unique([productId, fileId])
}

model MarketplaceLink {
  id         Int     @id @default(autoincrement())
  productId  Int
  platform   String
  productUrl String
  sortOrder  Int     @default(0)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────
model Order {
  id         Int      @id @default(autoincrement())
  platform   String   // shopee | lazada | tiki | sendo | website | other
  externalId String?  // mã đơn trên sàn (legacy)

  // Shopee
  shopeeShopId    Int?
  shopeeShop      ShopeeShop? @relation(fields: [shopeeShopId], references: [id])
  shopeeOrderSn   String?     @unique // order_sn từ Shopee API

  // Trạng thái theo Shopee: unpaid | ready_to_ship | processed | shipped | completed | in_cancel | cancelled | to_return
  status          String   @default("completed")

  // Người mua
  buyerUsername   String?
  recipientName   String?
  recipientPhone  String?
  shippingAddress String?  // địa chỉ đầy đủ
  city            String?
  district        String?
  ward            String?

  // Tài chính (đơn vị: VND)
  totalAmount     Int?
  shippingFee     Int?
  actualShippingFee Int?
  discountAmount  Int?     // giảm giá voucher/coin

  // Thanh toán
  paymentMethod   String?  // COD | CREDITCARD | AIRPAY | ...

  // Khác
  cancelReason    String?
  messageToSeller String?
  note            String?
  orderedAt       DateTime @default(now())
  syncedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items    OrderItem[]
  shipment Shipment?

  @@index([platform])
  @@index([orderedAt])
  @@index([shopeeShopId])
}

model OrderItem {
  id        Int    @id @default(autoincrement())
  orderId   Int
  productId Int
  variantId Int?
  quantity  Int    @default(1)
  price     Int    // giá tại thời điểm đặt hàng

  // Snapshot tại thời điểm đặt (tránh mất dữ liệu khi sản phẩm thay đổi)
  itemName        String? // tên sản phẩm
  modelName       String? // tên variant
  originalPrice   Int?    // giá gốc trước giảm
  discountedPrice Int?    // giá sau giảm

  // Shopee snapshot
  shopeeItemId  String?
  shopeeModelId String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// SHIPMENT — thông tin vận chuyển
// ─────────────────────────────────────────────
model Shipment {
  id             Int       @id @default(autoincrement())
  orderId        Int       @unique
  trackingNumber String?
  carrier        String?   // tên đơn vị vận chuyển (logistic channel)
  shopeeStatus   String?   // mã trạng thái logistics từ Shopee
  shippedAt      DateTime?
  deliveredAt    DateTime?
  updatedAt      DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// S3 CONFIG
// ─────────────────────────────────────────────
model S3Config {
  id              Int      @id @default(autoincrement())
  label           String   @default("default")
  bucket          String
  region          String
  accessKeyId     String
  secretAccessKey String
  endpoint        String?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────────────
// ASP.NET IDENTITY (auth)
// ─────────────────────────────────────────────
model AspNetUsers {
  id                   String    @id @default(cuid())
  userName             String?   @unique
  normalizedUserName   String?   @unique
  email                String?   @unique
  normalizedEmail      String?   @unique
  emailConfirmed       Boolean   @default(false)
  passwordHash         String?
  securityStamp        String?
  concurrencyStamp     String?
  phoneNumber          String?
  phoneNumberConfirmed Boolean   @default(false)
  twoFactorEnabled     Boolean   @default(false)
  lockoutEnd           DateTime?
  lockoutEnabled       Boolean   @default(true)
  accessFailedCount    Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  userRoles  AspNetUserRoles[]
  userClaims AspNetUserClaims[]
  userLogins AspNetUserLogins[]
  userTokens AspNetUserTokens[]
}

model AspNetRoles {
  id               String  @id @default(cuid())
  name             String? @unique
  normalizedName   String? @unique
  concurrencyStamp String?

  userRoles  AspNetUserRoles[]
  roleClaims AspNetRoleClaims[]
}

model AspNetUserRoles {
  userId String
  roleId String

  user AspNetUsers @relation(fields: [userId], references: [id], onDelete: Cascade)
  role AspNetRoles @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model AspNetUserClaims {
  id         Int     @id @default(autoincrement())
  userId     String
  claimType  String?
  claimValue String?

  user AspNetUsers @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AspNetRoleClaims {
  id         Int     @id @default(autoincrement())
  roleId     String
  claimType  String?
  claimValue String?

  role AspNetRoles @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([roleId])
}

model AspNetUserLogins {
  loginProvider       String
  providerKey         String
  providerDisplayName String?
  userId              String

  user AspNetUsers @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([loginProvider, providerKey])
  @@index([userId])
}

model AspNetUserTokens {
  userId        String
  loginProvider String
  name          String
  value         String?

  user AspNetUsers @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, loginProvider, name])
}
